# ===========================================
# Agent Arena — Environment Variables
# ===========================================
# Copy this file to .env and .env.local, then fill in the values.
# NEVER commit .env or .env.local to git!

# -------------------------------------------
# Frontend (VITE_ prefix — visible in browser, no secrets!)
# -------------------------------------------

# thirdweb client ID (public key, safe for frontend)
# Get from: https://thirdweb.com/dashboard → API Keys
VITE_THIRDWEB_CLIENT_ID=

# Supabase project URL and anon key (public, safe for frontend)
# Get from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -------------------------------------------
# Backend (Vercel Edge Functions — add as env vars in Vercel dashboard)
# -------------------------------------------

# Anthropic API key for Claude agent chat
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# thirdweb secret key (backend only!)
# Get from: https://thirdweb.com/dashboard → API Keys
THIRDWEB_SECRET_KEY=

# Private key for faucet/mint wallet (test AVAX distribution + NFT mint)
# WARNING: Use a TESTNET-ONLY wallet. Never put mainnet keys here.
FUJI_PRIVATE_KEY=

# Supabase URL (non-VITE version for backend)
SUPABASE_URL=

# Supabase service role key (full access — backend only!)
# Get from: https://supabase.com/dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=

# Deployed WorkshopNFT contract address on Fuji
NFT_CONTRACT_ADDRESS=

# -------------------------------------------
# Optional / Development
# -------------------------------------------

# Snowtrace API key (for contract verification)
# Get from: https://snowtrace.io/myapikey
ETHERSCAN_API_KEY=

# Sepolia testnet private key (for cross-chain testing)
SEPOLIA_PRIVATE_KEY=

# Google Gemini API key (for alternative AI features)
GEMINI_API_KEY=
