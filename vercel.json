{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|src/|node_modules/|@|__vite).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/agent.ts": {
      "maxDuration": 60
    },
    "api/generate-image.ts": {
      "maxDuration": 30
    },
    "api/instructor.ts": {
      "maxDuration": 60
    }
  }
}
